[configuration]
entry_symbol = "livekit_library_init"
compatibility_minimum = "4.1"

[libraries]
linux.debug.x86_64 = "res://addons/godot-livekit/bin/libgodot-livekit.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/godot-livekit/bin/libgodot-livekit.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://addons/godot-livekit/bin/libgodot-livekit.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/godot-livekit/bin/libgodot-livekit.windows.template_release.x86_64.dll"
macos.debug = "res://addons/godot-livekit/bin/libgodot-livekit.macos.template_debug.universal.dylib"
macos.release = "res://addons/godot-livekit/bin/libgodot-livekit.macos.template_release.universal.dylib"